DEBUG=false

JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

QUEUE_TTL=86400

# Очереди / приглашения / WebSocket
INVITE_TTL_SECONDS=3600
QUEUE_CODE_LENGTH=4
WS_MAX_CONNECTIONS_PER_USER=5
ROOM_LOCK_TIMEOUT=5.0
MAX_INVITES_PER_ROOM=20

# Лимиты запросов (slowapi-формат: "N/minute", "N/second")
RATE_LIMIT_QUEUE=30/minute
RATE_LIMIT_ADMIN=60/minute
RATE_LIMIT_AUTH=30/minute
RATE_LIMIT_FEEDBACK=5/minute

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s

CORS_ORIGINS=http://localhost:5173

APP_VERSION=v.test

# Telegram для «Сообщить о проблеме» (необязательно - иначе пишется в лог)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT=10.0
