{$CADDY_DOMAIN} {
    handle /health {
        respond 404
    }

    handle /api/* {
        reverse_proxy {$BACKEND_UPSTREAM}
    }

    handle /ws/* {
        reverse_proxy {$BACKEND_UPSTREAM}
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
